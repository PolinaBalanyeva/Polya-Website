---
import '../styles/global.css'; // ←これ！Tailwind v4を読み込みます

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja" data-theme="nord"> <head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-linear-to-b from-wakaba-shine to-wakaba text-base-content/80 selection:bg-success/20">
		<slot />
	</body>
</html>

<style>
	/* 元のstyleはそのままでOKです */
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>